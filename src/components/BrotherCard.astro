---
interface Props {
  name: string;
  classLetter: string;
  major?: string;
  detail?: string;
  photo?: string;
  variant?: "exec" | "default";
}
const { name, major, detail, classLetter, photo, variant = "default" } = Astro.props;
const isExec = variant === "exec";
const showPhoto = Boolean(photo);
---
<article class:list={[
  "relative bg-ivory border border-ink/10 rounded-md overflow-hidden shadow-plate",
  isExec && showPhoto && "p-4 flex items-center gap-5 min-h-[178px]",
  isExec && !showPhoto && "p-4",
  !isExec && showPhoto && "p-3 flex items-center gap-3 min-h-[92px]",
  !isExec && !showPhoto && "p-3 min-h-[68px]",
]}>
  {showPhoto && (
    <div class:list={[
      "relative shrink-0 flex items-center justify-center rounded overflow-hidden bg-ink",
      isExec ? "h-[126px] w-[150px]" : "h-[68px] w-[82px]",
    ]}>
      <img src={photo} alt={`${name} portrait`} class="h-full w-full object-cover" loading="lazy" />
      <span class="absolute left-2 bottom-2 inline-flex h-8 w-8 items-center justify-center rounded-full bg-gold text-ivory shadow-md">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <path d="M4 9V5h3v2h3V5h4v2h3V5h3v4v10H4V9z" />
          <path d="M9 19v-5h6v5" />
        </svg>
      </span>
    </div>
  )}

  <div class="min-w-0 flex-1">
    <p class:list={[
      "font-display leading-tight text-crimson",
      isExec ? "text-[1.05rem] md:text-[1.12rem]" : "text-[0.98rem] font-semibold text-ink",
    ]}>{isExec ? detail : name}</p>
    {isExec && <p class="font-semibold text-ink mt-2">{name}</p>}
    {major && (
      <p class:list={[
        "text-[0.72rem] text-ink/60 leading-snug mt-1",
        !isExec && "pr-12",
      ]}>{major}</p>
    )}
    {(isExec || detail) && (
      <>
        <span class="block h-px w-6 bg-gold my-2.5"></span>
        <p class:list={["text-ink/70 leading-relaxed break-words text-[0.72rem]"]}>{isExec ? classLetter : detail}</p>
      </>
    )}
  </div>

  {!isExec && <span class="absolute top-2 right-2 inline-flex h-6 min-w-[30px] items-center justify-center px-2 rounded-full bg-ivory border border-gold/55 text-[0.66rem] font-display text-gold-dim">{classLetter}</span>}
</article>
