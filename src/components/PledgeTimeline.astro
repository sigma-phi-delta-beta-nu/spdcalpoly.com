---
import { pledgeClasses } from "../data/pledge-classes";
---
<div class="relative">
  <!-- title -->
  <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
    <div>
      <p class="eyebrow text-crimson mb-2">Our Legacy of Brotherhood</p>
      <h3 class="font-display text-3xl md:text-4xl text-ink leading-none">
        <span class="headline-italic">Pledge classes</span> through the decades
      </h3>
    </div>
    <p class="text-sm text-ink/60 max-w-sm">Each Greek letter marks a new generation of Beta-Nu brothers, from the founding class to the men joining today.</p>
  </div>

  <!-- horizontal scroll rail -->
  <div class="relative">
    <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 timeline-rail h-px"></div>
    <ol class="relative flex items-center gap-7 md:gap-9 overflow-x-auto no-scrollbar pb-3 pt-2">
      {pledgeClasses.map((p, i) => (
        <li class="flex flex-col items-center min-w-[64px]">
          <span class:list={[
            "flex h-12 w-12 items-center justify-center rounded-full border bg-ivory font-display text-lg",
            i === pledgeClasses.length - 1 ? "border-crimson text-crimson shadow-[0_0_0_2px_rgba(164,21,30,0.08)]" : "border-gold/50 text-gold-dim",
          ]}>{p.letter}</span>
          <span class="mt-2 text-[0.65rem] tracking-[0.2em] uppercase text-ink/55 text-center">{p.name.split(" ")[0]}</span>
        </li>
      ))}
    </ol>
  </div>
</div>
