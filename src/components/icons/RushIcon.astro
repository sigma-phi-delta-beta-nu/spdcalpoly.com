---
// Small icon set for the recruitment timeline.
interface Props { name: "grill" | "ball" | "cards" | "briefcase" | "lock"; class?: string; size?: number; }
const { name, class: cls = "", size = 26 } = Astro.props;
---
{name === "grill" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M5 11 H27 L24 21 H8 Z" />
    <line x1="10" y1="21" x2="9" y2="27" />
    <line x1="22" y1="21" x2="23" y2="27" />
    <path d="M11 7 Q11 5 13 5" />
    <path d="M16 7 Q16 4 18 4" />
    <path d="M21 7 Q21 5 23 5" />
  </svg>
)}
{name === "ball" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <circle cx="16" cy="16" r="10" />
    <path d="M16 6 V26" />
    <path d="M6 16 H26" />
    <path d="M9 9 Q16 16 23 23" />
    <path d="M23 9 Q16 16 9 23" />
  </svg>
)}
{name === "cards" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <rect x="8" y="6" width="13" height="18" rx="1.5" transform="rotate(-8 14 15)" />
    <rect x="13" y="8" width="13" height="18" rx="1.5" transform="rotate(6 19 17)" />
    <path d="M19 14 L21 17 L19 20 L17 17 Z" />
  </svg>
)}
{name === "briefcase" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <rect x="4" y="10" width="24" height="16" rx="1.5" />
    <path d="M11 10 V7 a2 2 0 0 1 2 -2 H19 a2 2 0 0 1 2 2 V10" />
    <line x1="4" y1="17" x2="28" y2="17" opacity="0.6" />
    <rect x="14" y="15.5" width="4" height="3" rx="0.5" />
  </svg>
)}
{name === "lock" && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <rect x="7" y="14" width="18" height="14" rx="2" />
    <path d="M11 14 V10 a5 5 0 0 1 10 0 V14" />
    <circle cx="16" cy="21" r="1.6" />
  </svg>
)}
