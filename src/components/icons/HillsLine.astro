---
// Decorative gold line-art of SLO hills + a tiny castle silhouette for the footer.
interface Props { class?: string; }
const { class: cls = "" } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 600 120"
  preserveAspectRatio="none"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
>
  <!-- back range -->
  <path d="M0 80 L60 60 L110 72 L170 50 L230 70 L290 56 L350 74 L420 58 L480 72 L540 60 L600 78" opacity="0.55" />
  <!-- mid range -->
  <path d="M0 96 L70 80 L130 92 L200 76 L260 90 L330 78 L400 92 L470 80 L540 92 L600 84" opacity="0.7" />
  <!-- castle silhouette -->
  <g transform="translate(280 60)">
    <path d="M0 32 V20 H6 V24 H12 V20 H22 V24 H28 V20 H34 V32 Z" />
    <path d="M10 20 V10 H24 V20" />
    <rect x="14" y="22" width="6" height="10" />
  </g>
  <!-- palms -->
  <g opacity="0.7">
    <line x1="40" y1="100" x2="40" y2="80" />
    <path d="M40 80 Q36 76 32 78" />
    <path d="M40 80 Q44 76 48 78" />
    <path d="M40 80 Q38 74 40 70" />
    <line x1="560" y1="100" x2="560" y2="78" />
    <path d="M560 78 Q556 74 552 76" />
    <path d="M560 78 Q564 74 568 76" />
    <path d="M560 78 Q558 72 560 68" />
  </g>
</svg>
