---
import Base from "../layouts/Base.astro";
import CastleIcon from "../components/icons/CastleIcon.astro";
import Arrow from "../components/icons/Arrow.astro";
---
<Base
  title="404 — Page not found — Sigma Phi Delta Beta-Nu"
  description="The page you're looking for is not here. Return to the Sigma Phi Delta Beta-Nu home page."
  current="/404"
  navVariant="ivory"
  noindex
>
  <section class="relative min-h-[80vh] flex items-center paper">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10 py-24 grid lg:grid-cols-12 gap-12 items-center w-full">
      <div class="lg:col-span-7">
        <p class="eyebrow text-crimson mb-3">404 · Lost in the castle</p>
        <h1 class="headline text-ink text-[clamp(3rem,9vw,7rem)] leading-[0.94]">
          The drawbridge<br /><span class="headline-italic text-crimson">is up.</span>
        </h1>
        <p class="mt-6 max-w-lg text-ink/75 text-lg leading-relaxed">
          The page you were looking for isn't here. Try one of the doors below — or head back to the home page.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/" class="btn btn-primary">Home <Arrow size={14} /></a>
          <a href="/about" class="btn btn-ghost">About</a>
          <a href="/recruitment" class="btn btn-ghost">Recruitment</a>
          <a href="/brothers" class="btn btn-ghost">Brothers</a>
          <a href="/contact" class="btn btn-ghost">Contact</a>
        </div>
      </div>

      <div class="lg:col-span-5 hidden lg:flex justify-center">
        <div class="relative">
          <div class="absolute -inset-10 rounded-full bg-gradient-to-br from-crimson/10 to-transparent blur-3xl"></div>
          <CastleIcon class="text-crimson/80 relative" size={320} strokeWidth={0.9} />
        </div>
      </div>
    </div>
  </section>
</Base>
