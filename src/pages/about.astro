---
import Base from "../layouts/Base.astro";
import PledgeTimeline from "../components/PledgeTimeline.astro";
import CompassIcon from "../components/icons/CompassIcon.astro";
import CastleIcon from "../components/icons/CastleIcon.astro";
import Arrow from "../components/icons/Arrow.astro";
import { site } from "../data/site";

const heroImage = "/img_2023/formal_one.jpg";
const historyImage = "/img_2022/sig_phis.png";
const emphasisImage = "/img_2023/camping_two.JPG";
---

<Base
  title={`About the ${site.chapter} — Sigma Phi Delta at Cal Poly SLO`}
  description={`The principles, history, and modern character of the ${site.chapter} of Sigma Phi Delta at Cal Poly San Luis Obispo.`}
  current="/about"
>
  <!-- HERO -->
  <section class="relative isolate hero-duotone overflow-hidden h-[60vh] min-h-[420px] max-h-[640px]">
    <img src={heroImage} alt="Beta-Nu brothers at formal" class="absolute inset-0 h-full w-full object-cover object-center" />
    <div class="relative z-10 mx-auto max-w-[1440px] px-6 md:px-10 h-full flex items-end pb-12 md:pb-16">
      <div>
        <p class="eyebrow text-gold-soft rise-in">Chapter</p>
        <h1 class="headline text-ivory mt-4 text-[clamp(2.5rem,6vw,5rem)] rise-in delay-1">
          About the<br /><span class="headline-italic text-gold-soft">Beta-Nu Chapter</span>
        </h1>
        <p class="eyebrow text-ivory/60 mt-5 rise-in delay-2">
          Sigma Phi Delta &nbsp;·&nbsp; Beta-Nu Chapter &nbsp;·&nbsp; Cal Poly San Luis Obispo
        </p>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section class="relative py-24 md:py-28">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10 grid lg:grid-cols-12 gap-12">
      <!-- left column -->
      <div class="lg:col-span-4">
        <div class="text-gold mb-5"><CompassIcon size={44} strokeWidth={1.2} /></div>
        <p class="eyebrow text-crimson mb-3">Declaration of</p>
        <h2 class="font-display text-5xl md:text-6xl text-ink leading-[0.95] tracking-tightest">
          <span class="headline-italic">Principles</span>
        </h2>
      </div>

      <!-- body column -->
      <div class="lg:col-span-5 text-ink/85 leading-relaxed text-[1.02rem] space-y-5">
        <p>From time to time the Fraternity, of the Greek system, is called upon to set forth the principles for which it stands. We stand steadfast in our belief that we serve as a necessary adjunct to our Colleges and Universities in the training of young engineers.</p>
        <p>Our Constitution states, without equivocation, that the Object of the Fraternity shall be to promote the advancement of the Engineering Profession; to foster the advancement of Engineering Education; to instill a greater spirit of cooperation among Engineering Students; to inculcate in its members the highest ideals of virtuous manhood, good citizenship, and brotherhood; and to encourage excellence in scholarship.</p>
        <p>We are professional in that we admit only students enrolled in, or working toward, a degree in engineering. We are social in that we have houses where many of our members live together, and sponsor social and athletic programs for the active chapter and alumni.</p>
      </div>

      <!-- pull quote -->
      <aside class="lg:col-span-3 lg:pl-6 lg:border-l border-ink/10">
        <p class="font-display text-2xl text-crimson italic leading-snug">
          "The great aim of education is not knowledge but action."
        </p>
        <p class="eyebrow text-ink/55 mt-4">— Herbert Spencer</p>
      </aside>
    </div>
  </section>

  <!-- HISTORY SPOTLIGHT -->
  <section class="relative bg-ivory-warm/40 py-24 md:py-28 border-y border-ink/5">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative">
        <div class="absolute -inset-3 border border-gold/40 translate-x-3 translate-y-3 rounded-sm"></div>
        <div class="relative aspect-[4/3] overflow-hidden rounded-sm">
          <img src={historyImage} alt="Historical chapter photo" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
      <div>
        <p class="eyebrow text-crimson mb-3">National Fraternity</p>
        <h2 class="font-display text-4xl md:text-5xl text-ink leading-[1] tracking-tightest">
          History of the <span class="headline-italic">Fraternity</span>
        </h2>
        <div class="mt-6 space-y-4 text-ink/80 leading-relaxed">
          <p>Sigma Phi Delta was founded on <strong class="text-crimson">April 11, 1924</strong> at the University of Southern California in Los Angeles, by a small group of civil engineering students who recognized the need for a brotherhood devoted to the engineering profession itself.</p>
          <p>Today, Sigma Phi Delta recognizes <strong>36 chapters</strong> internationally.</p>
        </div>
        <div class="mt-8 flex items-center gap-6">
          <div>
            <p class="eyebrow text-ink/55">Motto</p>
            <p class="font-display text-xl text-crimson italic mt-1">Pro Bono Professionis</p>
          </div>
          <div class="h-10 w-px bg-ink/10"></div>
          <div>
            <p class="eyebrow text-ink/55">Founded</p>
            <p class="font-display text-xl text-ink mt-1">April 11, 1924</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BETA-NU SPOTLIGHT (reversed) -->
  <section class="relative py-24 md:py-28">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="lg:order-2 relative">
        <div class="absolute -inset-3 border border-crimson/30 -translate-x-3 -translate-y-3 rounded-sm"></div>
        <div class="relative aspect-[4/3] overflow-hidden rounded-sm">
          <img src={emphasisImage} alt="Beta-Nu brothers at camping" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
      <div class="lg:order-1">
        <p class="eyebrow text-crimson mb-3">The Beta-Nu Chapter</p>
        <h2 class="font-display text-4xl md:text-5xl text-ink leading-[1] tracking-tightest">
          Beta-Nu <span class="headline-italic">Emphasis</span>
        </h2>
        <div class="mt-6 space-y-4 text-ink/80 leading-relaxed">
          <p>As a professional-social fraternity of engineers, Sigma Phi Delta at Cal Poly San Luis Obispo strives to uphold the traditions of its Brotherhood while cultivating the skills and character engineers need to lead and serve.</p>
          <p>Beta-Nu continues the national mission locally: promoting the engineering profession, strengthening engineering education, encouraging cooperation among engineering students, and fostering brotherhood.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PLEDGE-CLASS TIMELINE -->
  <section class="relative paper py-24 md:py-28 border-t border-ink/5">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10">
      <PledgeTimeline />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-24">
    <div class="mx-auto max-w-[1440px] px-6 md:px-10">
      <div class="grid md:grid-cols-2 gap-6 items-stretch">
        <a href="/recruitment" class="group relative overflow-hidden bg-crimson p-10 md:p-12 text-ivory rounded-sm">
          <div class="absolute -right-12 -bottom-12 text-ivory/10">
            <CompassIcon size={220} strokeWidth={0.8} />
          </div>
          <p class="eyebrow text-gold-soft mb-3">Considering SPD?</p>
          <h3 class="font-display text-3xl md:text-4xl leading-[1.05]">See what <span class="headline-italic">rush</span> looks like.</h3>
          <p class="mt-3 text-ivory/80 max-w-md">Week 2 of Winter Quarter: BBQ, sports, games, professional night, and invite-only events.</p>
          <span class="mt-6 inline-flex items-center gap-3 text-ivory">Recruitment <Arrow size={16} class="arrow" /></span>
        </a>
        <a href="/contact" class="group relative overflow-hidden bg-ink p-10 md:p-12 text-ivory rounded-sm">
          <div class="absolute -right-12 -bottom-12 text-ivory/10">
            <CastleIcon size={220} strokeWidth={0.8} />
          </div>
          <p class="eyebrow text-gold-soft mb-3">Get in touch</p>
          <h3 class="font-display text-3xl md:text-4xl leading-[1.05]">Reach out to <span class="headline-italic">our officers.</span></h3>
          <p class="mt-3 text-ivory/80 max-w-md">Direct contacts for every elected and appointed position in the chapter.</p>
          <span class="mt-6 inline-flex items-center gap-3 text-gold">Contact <Arrow size={16} class="arrow" /></span>
        </a>
      </div>
    </div>
  </section>
</Base>
